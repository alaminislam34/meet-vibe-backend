{
  "info": {
    "name": "Meet Vibe API – Complete Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [{ "key": "base", "value": "http://localhost:5000/api/v1" }],
  "item": [
    {
      "name": "🔐 Authentication",
      "item": [
        { "name": "Register", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\",\"name\":\"Test User\"}" }, "url": { "raw": "{{base}}/auth/register", "host": ["{{base}}"], "path": ["auth","register"] } } },
        { "name": "Verify OTP", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\",\"otp\":\"123456\"}" }, "url": { "raw": "{{base}}/auth/verify-otp", "host": ["{{base}}"], "path": ["auth","verify-otp"] } } },
        { "name": "Resend OTP", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\"}" }, "url": { "raw": "{{base}}/auth/resend-otp", "host": ["{{base}}"], "path": ["auth","resend-otp"] } } },
        { "name": "Login", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\",\"password\":\"password123\"}" }, "url": { "raw": "{{base}}/auth/login", "host": ["{{base}}"], "path": ["auth","login"] } } },
        { "name": "MFA Login", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"mfaToken\":\"PASTE_MFA_TOKEN_HERE\",\"mfaCode\":\"123456\"}" }, "url": { "raw": "{{base}}/auth/mfa/login", "host": ["{{base}}"], "path": ["auth","mfa","login"] } } },
        { "name": "Refresh Token", "request": { "method": "POST", "url": { "raw": "{{base}}/auth/refresh", "host": ["{{base}}"], "path": ["auth","refresh"] } } },
        { "name": "Forgot Password", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\"}" }, "url": { "raw": "{{base}}/auth/forgot-password", "host": ["{{base}}"], "path": ["auth","forgot-password"] } } },
        { "name": "Reset Password", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"email\":\"user@example.com\",\"otp\":\"123456\",\"password\":\"newpassword123\"}" }, "url": { "raw": "{{base}}/auth/reset-password", "host": ["{{base}}"], "path": ["auth","reset-password"] } } },
        { "name": "Logout", "request": { "method": "POST", "url": { "raw": "{{base}}/auth/logout", "host": ["{{base}}"], "path": ["auth","logout"] } } },
        { "name": "MFA Setup (Generate Secret)", "request": { "method": "POST", "url": { "raw": "{{base}}/auth/mfa/setup", "host": ["{{base}}"], "path": ["auth","mfa","setup"] } } },
        { "name": "MFA Verify (Enable)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"code\":\"123456\"}" }, "url": { "raw": "{{base}}/auth/mfa/verify", "host": ["{{base}}"], "path": ["auth","mfa","verify"] } } },
        { "name": "MFA Request Recovery OTP", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"mfaToken\":\"PASTE_MFA_TOKEN_HERE\"}" }, "url": { "raw": "{{base}}/auth/mfa/request-recovery-otp", "host": ["{{base}}"], "path": ["auth","mfa","request-recovery-otp"] } } },
        { "name": "MFA Verify Recovery OTP", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"mfaToken\":\"PASTE_MFA_TOKEN_HERE\",\"otp\":\"123456\"}" }, "url": { "raw": "{{base}}/auth/mfa/verify-recovery-otp", "host": ["{{base}}"], "path": ["auth","mfa","verify-recovery-otp"] } } },
        { "name": "MFA Disable (Remove)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"password\":\"yourpassword123\",\"code\":\"123456\"}" }, "url": { "raw": "{{base}}/auth/mfa/disable", "host": ["{{base}}"], "path": ["auth","mfa","disable"] } } },
        { "name": "Google OAuth", "request": { "method": "GET", "url": { "raw": "{{base}}/auth/google", "host": ["{{base}}"], "path": ["auth","google"] } } },
        { "name": "Apple OAuth", "request": { "method": "GET", "url": { "raw": "{{base}}/auth/apple", "host": ["{{base}}"], "path": ["auth","apple"] } } }
      ]
    },
    {
      "name": "👤 User Profile",
      "item": [
        { "name": "Get My Profile", "request": { "method": "GET", "url": { "raw": "{{base}}/user/profile", "host": ["{{base}}"], "path": ["user","profile"] } } },
        { "name": "Update Profile", "request": { "method": "PUT", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"name\":\"Updated Name\",\"image\":\"https://example.com/avatar.jpg\"}" }, "url": { "raw": "{{base}}/user/profile", "host": ["{{base}}"], "path": ["user","profile"] } } },
        { "name": "Verify Identity (Stripe Session)", "request": { "method": "POST", "url": { "raw": "{{base}}/user/verify-identity", "host": ["{{base}}"], "path": ["user","verify-identity"] } } },
        { "name": "Delete Account", "request": { "method": "DELETE", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"reason\":\"No longer need this app\"}" }, "url": { "raw": "{{base}}/user/account", "host": ["{{base}}"], "path": ["user","account"] } } },
        { "name": "Mock Verify Identity (Direct)", "request": { "method": "POST", "url": { "raw": "{{base}}/user/mock-verify-identity", "host": ["{{base}}"], "path": ["user","mock-verify-identity"] } } },
        { "name": "Mock Stripe Webhook (Verified)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"},{"key":"stripe-signature","value":"t=123,v1=abc"}], "body": { "mode": "raw", "raw": "{\n  \"id\": \"evt_123\",\n  \"type\": \"identity.verification_session.verified\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"vs_123\",\n      \"last_verification_report\": \"vr_123\",\n      \"metadata\": {\n        \"userId\": \"PASTE_USER_ID_HERE\"\n      }\n    }\n  }\n}" }, "url": { "raw": "{{base}}/webhooks/stripe", "host": ["{{base}}"], "path": ["webhooks","stripe"] } } }
      ]
    },
    {
      "name": "💳 Subscriptions",
      "item": [
        { "name": "Subscribe (Get Plan)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"plan\":\"PREMIUM\"}" }, "url": { "raw": "{{base}}/subscription/subscribe", "host": ["{{base}}"], "path": ["subscription","subscribe"] } } },
        { "name": "Mock Subscribe (Direct)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"plan\":\"PREMIUM\"}" }, "url": { "raw": "{{base}}/subscription/mock-subscribe", "host": ["{{base}}"], "path": ["subscription","mock-subscribe"] } } },
        { "name": "Get Subscription Status", "request": { "method": "GET", "url": { "raw": "{{base}}/subscription/status", "host": ["{{base}}"], "path": ["subscription","status"] } } }
      ]
    },
    {
      "name": "📅 Events (5-Step Wizard)",
      "item": [
        { "name": "Step 1 – Basic Info", "request": { "method": "POST", "body": { "mode": "formdata", "formdata": [{"key":"coverImage","type":"file","src":[]},{"key":"title","value":"Tech Meetup 2026","type":"text"},{"key":"category","value":"Technology","type":"text"},{"key":"eventType","value":"Meetup","type":"text"},{"key":"capacity","value":"50","type":"text"},{"key":"isFree","value":"false","type":"text"},{"key":"price","value":"15","type":"text"}] }, "url": { "raw": "{{base}}/event/step1", "host": ["{{base}}"], "path": ["event","step1"] } } },
        { "name": "Step 2 – Date & Time", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\",\"startDate\":\"2026-12-20\",\"startTime\":\"18:00\",\"endDate\":\"2026-12-20\",\"endTime\":\"21:00\",\"timezone\":\"Asia/Dhaka\"}" }, "url": { "raw": "{{base}}/event/step2", "host": ["{{base}}"], "path": ["event","step2"] } } },
        { "name": "Step 3 – Location", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\",\"venueType\":\"OFFLINE\",\"venueName\":\"Dhaka Tech Hub\",\"address\":\"Banani, Dhaka\",\"mapLat\":23.7937,\"mapLng\":90.4066}" }, "url": { "raw": "{{base}}/event/step3", "host": ["{{base}}"], "path": ["event","step3"] } } },
        { "name": "Step 4 – Details", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\",\"agenda\":\"Networking, talks, demos\",\"whatToBring\":\"Laptop, business cards\",\"tags\":[\"tech\",\"networking\"],\"visibility\":\"PUBLIC\"}" }, "url": { "raw": "{{base}}/event/step4", "host": ["{{base}}"], "path": ["event","step4"] } } },
        { "name": "Step 5 – Publish", "request": { "method": "POST", "url": { "raw": "{{base}}/event/publish/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["event","publish","REPLACE_WITH_EVENT_ID"] } } },
        { "name": "List All Events (with filters)", "request": { "method": "GET", "url": { "raw": "{{base}}/event?category=Technology&venueType=OFFLINE&isFree=false", "host": ["{{base}}"], "path": ["event"], "query": [{"key":"category","value":"Technology"},{"key":"venueType","value":"OFFLINE"},{"key":"isFree","value":"false"}] } } },
        { "name": "My Events", "request": { "method": "GET", "url": { "raw": "{{base}}/event/mine", "host": ["{{base}}"], "path": ["event","mine"] } } },
        { "name": "Get Event Details", "request": { "method": "GET", "url": { "raw": "{{base}}/event/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["event","REPLACE_WITH_EVENT_ID"] } } },
        { "name": "Delete Event", "request": { "method": "DELETE", "url": { "raw": "{{base}}/event/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["event","REPLACE_WITH_EVENT_ID"] } } }
      ]
    },
    {
      "name": "🎟️ Participations",
      "item": [
        { "name": "Join Event", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\"}" }, "url": { "raw": "{{base}}/participation/join", "host": ["{{base}}"], "path": ["participation","join"] } } },
        { "name": "Submit Bank Transfer", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"eventId\":\"REPLACE_WITH_EVENT_ID\",\"transactionId\":\"TXN-12345\"}" }, "url": { "raw": "{{base}}/participation/pay-transfer", "host": ["{{base}}"], "path": ["participation","pay-transfer"] } } },
        { "name": "Get Pending Payments (Host)", "request": { "method": "GET", "url": { "raw": "{{base}}/participation/pending-payments/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["participation","pending-payments","REPLACE_WITH_EVENT_ID"] } } },
        { "name": "Verify Payment – Approve/Reject (Host)", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"participationId\":\"REPLACE_WITH_PARTICIPATION_ID\",\"action\":\"APPROVED\"}" }, "url": { "raw": "{{base}}/participation/verify-payment", "host": ["{{base}}"], "path": ["participation","verify-payment"] } } }
      ]
    },
    {
      "name": "🤝 Connections",
      "item": [
        { "name": "Send Connection Request", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"receiverId\":\"REPLACE_WITH_USER_ID\",\"requestMessage\":\"Hey! We met at the hackathon.\"}" }, "url": { "raw": "{{base}}/connection/request", "host": ["{{base}}"], "path": ["connection","request"] } } },
        { "name": "Respond to Request", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"connectionId\":\"REPLACE_WITH_CONNECTION_ID\",\"action\":\"ACCEPTED\"}" }, "url": { "raw": "{{base}}/connection/respond", "host": ["{{base}}"], "path": ["connection","respond"] } } },
        { "name": "Get Friends List", "request": { "method": "GET", "url": { "raw": "{{base}}/connection", "host": ["{{base}}"], "path": ["connection"] } } },
        { "name": "Get Pending Requests", "request": { "method": "GET", "url": { "raw": "{{base}}/connection/pending", "host": ["{{base}}"], "path": ["connection","pending"] } } },
        { "name": "Remove Connection", "request": { "method": "DELETE", "url": { "raw": "{{base}}/connection/REPLACE_WITH_CONNECTION_ID", "host": ["{{base}}"], "path": ["connection","REPLACE_WITH_CONNECTION_ID"] } } }
      ]
    },
    {
      "name": "💬 Chat",
      "item": [
        { "name": "Get Conversation List (DMs)", "request": { "method": "GET", "url": { "raw": "{{base}}/chat/conversations", "host": ["{{base}}"], "path": ["chat","conversations"] } } },
        { "name": "Get Group Messages", "request": { "method": "GET", "url": { "raw": "{{base}}/chat/group/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["chat","group","REPLACE_WITH_EVENT_ID"] } } },
        { "name": "Send Group Message", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"message\":\"Hey everyone! Excited for the event!\"}" }, "url": { "raw": "{{base}}/chat/group/REPLACE_WITH_EVENT_ID", "host": ["{{base}}"], "path": ["chat","group","REPLACE_WITH_EVENT_ID"] } } },
        { "name": "Get Private Messages", "request": { "method": "GET", "url": { "raw": "{{base}}/chat/private/REPLACE_WITH_USER_ID", "host": ["{{base}}"], "path": ["chat","private","REPLACE_WITH_USER_ID"] } } },
        { "name": "Send Private Message", "request": { "method": "POST", "header": [{"key":"Content-Type","value":"application/json"}], "body": { "mode": "raw", "raw": "{\"message\":\"Hey! How are you?\"}" }, "url": { "raw": "{{base}}/chat/private/REPLACE_WITH_USER_ID", "host": ["{{base}}"], "path": ["chat","private","REPLACE_WITH_USER_ID"] } } }
      ]
    }
  ]
}
