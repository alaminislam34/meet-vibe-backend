# Server configuration
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5000

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/meet_vibe?schema=public"

# Authentication
JWT_SECRET="your-super-secure-jwt-secret-key"
JWT_EXPIRES_IN="7d"

# Google OAuth Configuration
GOOGLE_CLIENT_ID="google-client-id-here"
GOOGLE_CLIENT_SECRET="google-client-secret-here"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/v1/auth/google/callback"

# Apple OAuth Configuration
APPLE_CLIENT_ID="apple-services-id-here"
APPLE_TEAM_ID="apple-team-id-here"
APPLE_KEY_ID="apple-key-id-here"
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
APPLE_CALLBACK_URL="https://yourdomain.com/api/v1/auth/apple/callback"

# AWS Configuration (for AWS Rekognition - Verification Module)
AWS_ACCESS_KEY_ID="your-aws-access-key-id"
AWS_SECRET_ACCESS_KEY="your-aws-secret-access-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="meet-vibe-verification-uploads"

# Stripe Configuration (Alternative Identity Check or Subscription Payment)
STRIPE_API_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# SMTP Mailer Configuration
SMTP_HOST="smtp.mailtrap.io"
SMTP_PORT=2525
SMTP_USER="smtp-username"
SMTP_PASS="smtp-password"
SMTP_FROM="noreply@meetvibe.com"

# Better Auth Configuration
BETTER_AUTH_SECRET="your-better-auth-secret-here-at-least-32-characters"
BETTER_AUTH_URL="http://localhost:5000"
