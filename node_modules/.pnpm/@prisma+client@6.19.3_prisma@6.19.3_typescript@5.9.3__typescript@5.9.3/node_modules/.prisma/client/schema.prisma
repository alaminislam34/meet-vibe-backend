datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model ChatGroup {
  id        String   @id @default(uuid())
  eventId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event    Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id          String   @id @default(uuid())
  chatGroupId String? // Null for private DMs
  senderId    String
  receiverId  String? // Null for group messages
  message     String
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  chatGroup ChatGroup? @relation(fields: [chatGroupId], references: [id], onDelete: Cascade)
  sender    User       @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiver  User?      @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
}

model Connection {
  id             String   @id @default(uuid())
  requesterId    String
  receiverId     String
  status         String   @default("PENDING") // "PENDING", "ACCEPTED", "DECLINED"
  requestMessage String? // Optional message attached when sending request (like LinkedIn)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  requester User @relation("SentConnections", fields: [requesterId], references: [id], onDelete: Cascade)
  receiver  User @relation("ReceivedConnections", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([requesterId, receiverId])
}

model Event {
  id           String @id @default(uuid())
  creatorId    String
  status       String @default("DRAFT") // "DRAFT", "PUBLISHED", "CANCELLED"
  creationStep Int    @default(1)

  // Step 1 – Basic Info
  coverImage String?
  title      String  @default("")
  category   String  @default("") // e.g. "Music", "Sports", "Tech"
  eventType  String  @default("") // e.g. "Conference", "Party", "Workshop"
  capacity   Int     @default(0)
  isFree     Boolean @default(true)
  price      Decimal @default(0.00)

  // Step 2 – Date & Time
  startDate DateTime?
  startTime String?
  endDate   DateTime?
  endTime   String?
  timezone  String    @default("UTC")

  // Step 3 – Location
  venueType  String  @default("OFFLINE") // "ONLINE", "OFFLINE"
  venueName  String?
  address    String?
  mapLat     Float?
  mapLng     Float?
  onlineLink String? // Zoom / Meet link

  // Step 4 – Details
  agenda      String? // What to expect
  whatToBring String?
  tags        String[] @default([])
  visibility  String   @default("PUBLIC") // "PUBLIC", "FRIENDS_ONLY"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator      User          @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  participants Participant[]
  chatGroup    ChatGroup?
}

model Participant {
  id            String   @id @default(uuid())
  eventId       String
  userId        String
  status        String // "PENDING_PAYMENT", "PENDING_APPROVAL", "APPROVED", "REJECTED"
  transactionId String? // User-submitted payment proof
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
}

model Subscription {
  id        String   @id @default(uuid())
  userId    String   @unique
  plan      String // e.g. "FREE", "MONTHLY_STANDARD", "YEARLY_PREMIUM"
  status    String // "ACTIVE", "EXPIRED", "CANCELLED"
  startDate DateTime
  endDate   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id         String    @id @default(uuid())
  email      String    @unique
  password   String?
  name       String
  image      String?
  isVerified Boolean   @default(false)
  otpCode    String?
  otpExpiry  DateTime?
  provider   String    @default("LOCAL") // "LOCAL", "GOOGLE", "APPLE"
  providerId String?

  // Identity verification
  is18Plus           Boolean @default(false)
  isHuman            Boolean @default(false)
  govIdUrl           String?
  faceImageUrl       String?
  verificationStatus String  @default("UNVERIFIED") // "UNVERIFIED", "PENDING", "VERIFIED", "REJECTED"

  // Account status
  deletedAt    DateTime? // Soft delete
  deleteReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription        Subscription?
  events              Event[]
  participations      Participant[]
  sentConnections     Connection[]  @relation("SentConnections")
  receivedConnections Connection[]  @relation("ReceivedConnections")
  sentMessages        ChatMessage[] @relation("SentMessages")
  receivedMessages    ChatMessage[] @relation("ReceivedMessages")
}
